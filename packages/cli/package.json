{
  "name": "@vybit/cli",
  "version": "1.0.0",
  "description": "Command-line interface for the Vybit notification platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "vybit": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsc --watch",
    "test": "jest --config ../../jest.config.js --rootDir ../..",
    "lint": "echo 'Run lint from root: npm run lint'"
  },
  "keywords": [
    "vybit",
    "cli",
    "notifications",
    "command-line"
  ],
  "author": "Flatirontek LLC",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/flatirontek/vybit-sdk.git",
    "directory": "packages/cli"
  },
  "homepage": "https://gitlab.com/flatirontek/vybit-sdk#readme",
  "bugs": {
    "url": "https://gitlab.com/flatirontek/vybit-sdk/-/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@vybit/api-sdk": "^1.2.0",
    "@vybit/core": "^1.3.0",
    "commander": "^12.0.0"
  }
}
